# Deployment Environment Variables Example
# Copy this to .env and fill in your values

# GitHub Repository
GITHUB_REPO=https://github.com/YOUR_USERNAME/schedulist.git
BRANCH=main

# Database Configuration
DB_NAME=schedulist
DB_USER=schedulist_user
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432

# For Digital Ocean Managed Database, use:
# DB_HOST=your-db-cluster.db.ondigitalocean.com
# DB_PORT=25060
# DB_SSL=true
# DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Application Secrets
JWT_SECRET=generate_a_secure_random_string_here
ENCRYPTION_KEY=generate_another_secure_random_string_here

# Optional: S3 Backup Configuration
# S3_BUCKET=your-backup-bucket
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1

# Optional: Email Configuration (for future use)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Optional: Monitoring (for future use)
# SENTRY_DSN=your_sentry_dsn
# NEW_RELIC_LICENSE_KEY=your_new_relic_key